env_name                     = "production"
aws_region                   = "us-east-1"
vpc_cidr                     = "10.30.0.0/16"
azs                          = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnets               = ["10.30.1.0/24", "10.30.2.0/24", "10.30.3.0/24"]
private_subnets              = ["10.30.11.0/24", "10.30.12.0/24", "10.30.13.0/24"]
eks_version                  = "1.30"
node_instance_types          = ["m6i.large"]
node_min_size                = 2
node_max_size                = 6
node_desired_size            = 3
postgres_engine_version      = "16.3"
postgres_instance_class      = "db.m6i.large"
postgres_allocated_storage   = 200
postgres_username            = "autoqual"
postgres_password            = "replace_me"
postgres_multi_az            = true
postgres_backup_retention_days = 14
redis_node_type              = "cache.m6i.large"
redis_node_count             = 2
redis_auth_token             = "replace_me"
opensearch_engine_version    = "OpenSearch_2.13"
opensearch_instance_type     = "m6g.large.search"
opensearch_instance_count    = 2
opensearch_master_username   = "autoqual"
opensearch_master_password   = "replace_me"
raw_media_bucket             = "autoqual-prod-raw-media"
derived_media_bucket         = "autoqual-prod-derived-media"
database_secret_json         = "{\"DATABASE_URL\":\"replace_me\"}"
app_secret_json              = "{\"JWT_SECRET\":\"replace_me\",\"EMBED_SECRET\":\"replace_me\"}"
log_retention_days           = 90
domain_name                  = "yourdomain.com"
hosted_zone_id               = "Z1234567890"
origin_domain_name           = "prod-alb.example.com"
acm_certificate_arn          = "arn:aws:acm:us-east-1:123456789012:certificate/replace_me"
