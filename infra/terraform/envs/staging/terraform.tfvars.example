env_name                     = "staging"
aws_region                   = "us-east-1"
vpc_cidr                     = "10.20.0.0/16"
azs                          = ["us-east-1a", "us-east-1b"]
public_subnets               = ["10.20.1.0/24", "10.20.2.0/24"]
private_subnets              = ["10.20.11.0/24", "10.20.12.0/24"]
eks_version                  = "1.30"
node_instance_types          = ["t3.large"]
node_min_size                = 1
node_max_size                = 3
node_desired_size            = 2
postgres_engine_version      = "16.3"
postgres_instance_class      = "db.t3.medium"
postgres_allocated_storage   = 100
postgres_username            = "autoqual"
postgres_password            = "CHANGE_ME"
postgres_multi_az            = false
postgres_backup_retention_days = 7
redis_node_type              = "cache.t3.small"
redis_node_count             = 1
redis_auth_token             = "CHANGE_ME"
opensearch_engine_version    = "OpenSearch_2.13"
opensearch_instance_type     = "t3.small.search"
opensearch_instance_count    = 1
opensearch_master_username   = "autoqual"
opensearch_master_password   = "CHANGE_ME"
raw_media_bucket             = "autoqual-staging-raw-media"
derived_media_bucket         = "autoqual-staging-derived-media"
database_secret_json         = "{\"DATABASE_URL\":\"CHANGE_ME\"}"
app_secret_json              = "{\"JWT_SECRET\":\"CHANGE_ME\",\"EMBED_SECRET\":\"CHANGE_ME\"}"
log_retention_days           = 30
domain_name                  = "staging.yourdomain.com"
hosted_zone_id               = "CHANGE_ME"
origin_domain_name           = "CHANGE_ME"
acm_certificate_arn          = "CHANGE_ME"
