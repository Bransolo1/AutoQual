# ─────────────────────────────────────────────────────────────────────────────
# AutoQual Web – Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Public var: exposed to the browser. Points to the API base URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Session (server-side only) ────────────────────────────────────────────────
# REQUIRED in production. Random 32+ byte secret for signing the session cookie.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-32-char-min-random-secret

# ── SSO / OIDC (server-side only) ────────────────────────────────────────────
# Must match the values configured in the API.
# SSO_ISSUER_URL=https://accounts.google.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=http://localhost:3000/auth/callback
# SSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# ── Feature flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SSO_ENABLED=false
