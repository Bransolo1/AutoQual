# ─────────────────────────────────────────────────────────────────────────────
# AutoQual API – Environment Variables
# Copy to .env for local development. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development   # development | test | production

# ── Database (Postgres) ───────────────────────────────────────────────────────
# REQUIRED. Full PostgreSQL connection string.
DATABASE_URL=postgresql://sensehub:sensehub@localhost:5432/sensehub?schema=public

# ── Redis (BullMQ job queue + token revocation cache) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Set REDIS_AUTH_TOKEN when Redis requires AUTH (e.g., AWS ElastiCache TLS)
# REDIS_AUTH_TOKEN=

# ── OpenSearch (full-text search) ────────────────────────────────────────────
# REQUIRED.
OPENSEARCH_URL=http://localhost:9200
# Leave blank for dev (security disabled); set for production.
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ── Object Storage (S3 / MinIO) ───────────────────────────────────────────────
# REQUIRED.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=sensehub
S3_SECRET_KEY=sensehubstorage
S3_BUCKET=sensehub

# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=mock   # mock | openai | anthropic
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Exactly ONE of JWT_JWKS_URL, JWT_PUBLIC_KEY, or JWT_SECRET must be set.
#
# Option A – OIDC JWKS (production, recommended):
# JWT_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
# JWT_ISSUER=https://your-idp.example.com
# JWT_AUDIENCE=autoqual-api
# JWT_ALGORITHM=RS256
#
# Option B – RSA public key (PEM):
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_ALGORITHM=RS256
#
# Option C – HMAC secret (dev / simple setups):
JWT_SECRET=change-me-in-production-min-32-chars-long
# JWT_ALGORITHM=HS256

# Require jti claim and enable per-token revocation checks:
JWT_REQUIRE_JTI=false

# ── SSO / OIDC ────────────────────────────────────────────────────────────────
SSO_ENABLED=false
# SSO_ISSUER_URL=https://accounts.google.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=http://localhost:3000/auth/callback
# SSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
# SSO_ALLOWED_DOMAINS=yourdomain.com
# SSO_GROUP_ROLE_MAP={"engineering":"admin","research":"researcher"}
# SSO_DEFAULT_ROLE=researcher
# SSO_REQUIRE_MFA=false
# SSO_MFA_CLAIM=

# ── Embed (signed public embed tokens) ───────────────────────────────────────
# REQUIRED. Min 16 characters. Rotate regularly.
EMBED_SECRET=change-me-embed-secret-min-16
# EMBED_COMPLETION_WEBHOOK_URL=https://your-app.example.com/webhooks/embed

# ── Web / CORS ────────────────────────────────────────────────────────────────
# REQUIRED. Base URL of the web frontend.
WEB_BASE_URL=http://localhost:3000
# REQUIRED. Comma-separated list of allowed CORS origins.
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60       # window in seconds
THROTTLE_LIMIT=120    # max requests per window per IP

# ── Audit Retention ───────────────────────────────────────────────────────────
AUDIT_RETENTION_ALLOW=false
AUDIT_RETENTION_DAYS=365

# ── Token Revocation Purge ───────────────────────────────────────────────────
TOKEN_REVOCATION_PURGE_ENABLED=false

# ── Secrets Backend ───────────────────────────────────────────────────────────
SECRETS_PROVIDER=env   # env | vault
# VAULT_ADDR=https://vault.example.com
# VAULT_ROLE=autoqual-api
# VAULT_TOKEN=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=sensehub-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── Stripe Billing ────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── SSO Config ────────────────────────────────────────────────────────────────
# Optional: force all workspaces to use the platform-level SSO (overrides per-workspace config)
FORCE_PLATFORM_SSO=false

# ── Media Retention ───────────────────────────────────────────────────────────
MEDIA_RETENTION_DAYS=365
