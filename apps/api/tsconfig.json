{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "../../",
    "rootDirs": ["src", "../../packages"],
    "outDir": "dist",
    "noEmit": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": ["node", "express", "multer"]
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts", "../../packages/**/*.ts"]
}
