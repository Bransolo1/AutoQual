# AutoQual environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=autoqual
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=autoqual
# Full DSN used by Prisma (api + worker)
DATABASE_URL=postgresql://autoqual:<password>@localhost:5432/autoqual

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API server ────────────────────────────────────────────────────────────────
# Port the NestJS API listens on
PORT=4000

# ── Google OAuth (recommended sign-in method) ────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Add Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# Must match an Authorized redirect URI in your Google Cloud Console exactly
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Workspace ID to assign Google sign-in users to (auto-provisioned if absent)
DEFAULT_WORKSPACE_ID=default

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign session cookies (min 32 chars)
SESSION_SECRET=<your-session-secret-min-32-chars>
# JWT issuer and audience (must match your IdP config)
JWT_ISSUER=https://your-auth-provider.example.com
JWT_AUDIENCE=autoqual-api

# ── AI provider ───────────────────────────────────────────────────────────────
# Which provider to use: openai | anthropic | mock
AI_PROVIDER=mock
# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini
# Anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Insight generation: max retry attempts (default 3)
AI_INSIGHT_MAX_ATTEMPTS=3
# Optional: override the default AI model for insights
AI_MODEL=

# ── Speech-to-text ────────────────────────────────────────────────────────────
# Deepgram (leave blank to use synthetic transcripts)
DEEPGRAM_API_KEY=<your-deepgram-api-key>

# ── Embed (participant widget) ────────────────────────────────────────────────
# HMAC secret for signing embed tokens (min 32 chars)
EMBED_SECRET=<your-embed-secret-min-32-chars>
# Optional webhook: called when a participant completes an embed session
EMBED_COMPLETION_WEBHOOK_URL=

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
# Public API URL — accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Storage (optional) ────────────────────────────────────────────────────────
# S3-compatible storage for video uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
